/* 全局样式 */
page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #333;
}
.container {
  padding: 20rpx;
}
.title {
  font-size: 40rpx;
