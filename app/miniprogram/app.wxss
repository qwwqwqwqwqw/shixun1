/* 全局样式 */
page {
  background: #f0f4f2;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #333;
}
.container {
  box-sizing: border-box;
  padding: 24rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin: 20rpx 0;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  margin: 20rpx 0;
}
