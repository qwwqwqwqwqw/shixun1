<view class="container">
  <text class="title">导航状态</text>

  <view class="connection-bar {{connected ? 'online' : 'offline'}}"
        bindtap="reconnect">
    {{connected ? '● 已连接小车' : '● 连接已断开，点击重连'}}
  </view>

  <view class="status-card">
    <view class="info-row">
      <text class="label">目标教室</text>
      <text class="value">{{targetRoom || (faceMode ? '识别后确定' : '未设置')}}</text>
    </view>
    <view class="info-row face-row" wx:if="{{faceMode || faceStatus}}">
      <text class="label">人脸识别</text>
      <view class="face-value">
        <text class="value">{{faceStatus || '等待识别'}}</text>
        <text class="face-name" wx:if="{{recognizedName}}">
          识别用户：{{recognizedName}}
        </text>
      </view>
    </view>
    <view class="info-row">
      <text class="label">当前状态</text>
      <text class="value {{statusClass}}">{{status}}</text>
    </view>
    <view class="info-row">
      <text class="label">小车位置</text>
      <text class="value position">{{positionText}}</text>
    </view>
    <view class="info-row">
      <text class="label">到达确认</text>
      <text class="value {{arrivalConfirmed ? 'ok' : 'pending'}}">
        {{arrivalConfirmed ? '✓ 已确认' : '待确认'}}
      </text>
    </view>
  </view>

  <button class="btn-cancel" bindtap="cancelNavigation">
    {{faceMode ? '停止人脸识别' : '取消导航'}}
  </button>
</view>
