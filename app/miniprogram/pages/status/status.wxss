.connection-bar {
  padding: 18rpx 24rpx; margin: 20rpx 0;
  border-radius: 12rpx; text-align: center; font-size: 26rpx;
}
.connection-bar.online { color: #07853f; background: #e8f8ef; }
.connection-bar.offline { color: #cf1322; background: #fff1f0; }
.status-card {
  background: #fff; border-radius: 16rpx; padding: 30rpx; margin: 20rpx 0;
}
.info-row {
  display: flex; justify-content: space-between; padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}
.info-row:last-child { border-bottom: none; }
.label { color: #999; }
.value { max-width: 68%; font-weight: bold; text-align: right; }
.value.running { color: #1677ff; }
.value.arrived { color: #07c160; }
.value.failed { color: #e64340; }
.value.position { font-size: 26rpx; font-weight: normal; }
.value.ok { color: #07c160; }
.value.pending { color: #faad14; }
.face-value {
  display: flex; flex-direction: column; align-items: flex-end;
  max-width: 68%;
}
.face-value .value { max-width: 100%; color: #1677ff; }
.face-name { margin-top: 8rpx; color: #07c160; font-size: 24rpx; }
.btn-cancel {
  margin-top: 30rpx; color: #e64340; background: #fff;
  border: 2rpx solid #e64340; border-radius: 12rpx;
}
