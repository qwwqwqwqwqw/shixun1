<view class="container">
  <view class="header">
    <text class="title">iCar 智能教室导航</text>
    <view class="connection {{connected ? 'online' : 'offline'}}"
          bindtap="reconnect">
      <view class="connection-dot"></view>
      <text>{{connected ? '小车已连接' : '未连接，点击重试'}}</text>
    </view>
  </view>

  <view class="section-title">请选择教室</view>
  <view class="room-list">
    <view wx:for="{{rooms}}" wx:key="*this"
          class="room-item {{item == selectedRoom ? 'active' : ''}}"
          bindtap="selectRoom" data-room="{{item}}">
      {{item}}
    </view>
  </view>

  <view class="section-title">或输入其他教室号</view>
  <input class="room-input"
         value="{{customRoom}}"
         maxlength="32"
         placeholder="例如：201"
         bindinput="inputRoom" />

  <button class="btn-primary" bindtap="startNavigate">开始导航</button>

  <view class="manual-card">
    <view class="manual-header">
      <view>
        <text class="manual-title">手动控制</text>
        <text class="manual-subtitle">以小车车头方向为基准</text>
      </view>
      <view class="safety-badge">松手即停</view>
    </view>

    <view class="control-grid">
      <view class="control-btn forward {{manualActive == 'forward' ? 'pressed' : ''}}"
            data-action="forward"
            catchtouchstart="startManualControl"
            catchtouchend="stopManualControl"
            catchtouchcancel="stopManualControl">
        <text class="control-icon">↑</text>
        <text class="control-label">前进</text>
      </view>
      <view class="control-btn shift-left {{manualActive == 'shiftLeft' ? 'pressed' : ''}}"
            data-action="shiftLeft"
            catchtouchstart="startManualControl"
            catchtouchend="stopManualControl"
            catchtouchcancel="stopManualControl">
        <text class="control-icon">←</text>
        <text class="control-label">左移</text>
      </view>
      <view class="control-btn stop" bindtap="emergencyStop">
        <text class="stop-icon">■</text>
        <text class="control-label">停止</text>
      </view>
      <view class="control-btn shift-right {{manualActive == 'shiftRight' ? 'pressed' : ''}}"
            data-action="shiftRight"
            catchtouchstart="startManualControl"
            catchtouchend="stopManualControl"
            catchtouchcancel="stopManualControl">
        <text class="control-icon">→</text>
        <text class="control-label">右移</text>
      </view>
      <view class="control-btn backward {{manualActive == 'backward' ? 'pressed' : ''}}"
            data-action="backward"
            catchtouchstart="startManualControl"
            catchtouchend="stopManualControl"
            catchtouchcancel="stopManualControl">
        <text class="control-icon">↓</text>
        <text class="control-label">后退</text>
      </view>
    </view>

    <view class="turn-title">原地旋转</view>
    <view class="turn-controls">
      <view class="turn-btn {{manualActive == 'turnLeft' ? 'pressed' : ''}}"
            data-action="turnLeft"
            catchtouchstart="startManualControl"
            catchtouchend="stopManualControl"
            catchtouchcancel="stopManualControl">
        <text class="turn-icon">↺</text>
        <text>向左旋转</text>
      </view>
      <view class="turn-btn {{manualActive == 'turnRight' ? 'pressed' : ''}}"
            data-action="turnRight"
            catchtouchstart="startManualControl"
            catchtouchend="stopManualControl"
            catchtouchcancel="stopManualControl">
        <text>向右旋转</text>
        <text class="turn-icon">↻</text>
      </view>
    </view>
    <text class="manual-tip">按住方向键持续运动，松开后自动停车</text>
  </view>

  <view class="divider">或</view>
  <button class="btn-face" bindtap="startFaceRecognition">
    人脸识别导航
  </button>
</view>
