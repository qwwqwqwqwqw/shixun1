.section-title { font-size: 30rpx; margin: 20rpx 0 10rpx; color: #666; }
.room-list { display: flex; flex-wrap: wrap; gap: 20rpx; }
.room-item {
  width: 140rpx; height: 100rpx;
  display: flex; align-items: center; justify-content: center;
  border: 2rpx solid #ddd; border-radius: 12rpx; font-size: 32rpx;
}
.room-item.active {
  background: #07c160; color: #fff; border-color: #07c160;
}
.divider { text-align: center; color: #ccc; margin: 30rpx 0; }
.btn-face { background: #576b95; color: #fff; border-radius: 12rpx; }
