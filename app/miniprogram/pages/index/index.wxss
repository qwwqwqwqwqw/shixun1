.home-page { padding-bottom: 48rpx; }
.hero {
  position: relative; overflow: hidden;
  padding: 42rpx 34rpx 34rpx; margin-bottom: 24rpx;
  color: #fff; background: linear-gradient(145deg, #163f35, #08764d);
  border-radius: 32rpx;
}
.hero-copy { position: relative; z-index: 1; }
.eyebrow {
  display: block; margin-bottom: 12rpx;
  color: rgba(255, 255, 255, .7); font-size: 22rpx;
  letter-spacing: 3rpx;
}
.hero-title {
  display: block; font-size: 48rpx;
  font-weight: 700; letter-spacing: 1rpx;
}
.hero-subtitle {
  display: block; margin-top: 12rpx;
  color: rgba(255, 255, 255, .76); font-size: 25rpx;
}
.connection {
  position: relative; z-index: 1;
  display: inline-flex; align-items: center;
  margin-top: 28rpx; padding: 11rpx 20rpx;
  border-radius: 30rpx; font-size: 23rpx;
}
.connection.online { color: #e8fff3; background: rgba(255, 255, 255, .15); }
.connection.offline { color: #ffe7e5; background: rgba(143, 25, 25, .38); }
.connection-dot {
  width: 13rpx; height: 13rpx; margin-right: 12rpx;
  border-radius: 50%; background: #5ff2a9;
}
.connection.offline .connection-dot { background: #ff8c86; }
.navigation-card {
  padding: 30rpx; background: #fff;
  border: 1rpx solid #e6eeea; border-radius: 28rpx;
}
.card-heading {
  display: flex; align-items: flex-start; justify-content: space-between;
  margin-bottom: 26rpx;
}
.card-title {
  display: block; color: #1c2924;
  font-size: 34rpx; font-weight: 700;
}
.card-subtitle {
  display: block; margin-top: 8rpx;
  color: #8a9691; font-size: 23rpx;
}
.step-badge {
  display: flex; align-items: center; justify-content: center;
  width: 56rpx; height: 56rpx;
  color: #0a8a59; background: #e7f7ef;
  border-radius: 18rpx; font-size: 23rpx; font-weight: 700;
}
.input-shell {
  display: flex; align-items: center;
  box-sizing: border-box; height: 96rpx;
  padding: 0 22rpx; background: #f4f7f5;
  border: 2rpx solid transparent; border-radius: 20rpx;
}
.input-prefix {
  padding-right: 20rpx; margin-right: 20rpx;
  color: #426057; border-right: 1rpx solid #d6dfda;
  font-size: 25rpx; font-weight: 600;
}
.room-input {
  flex: 1; height: 96rpx;
  color: #15241f; font-size: 31rpx; font-weight: 600;
}
.input-placeholder { color: #aab4b0; font-size: 27rpx; font-weight: 400; }
.navigate-button {
  display: flex; align-items: center; justify-content: center;
  height: 94rpx; margin: 22rpx 0 0;
  color: #fff; background: #087a50;
  border-radius: 22rpx; font-size: 29rpx; font-weight: 700;
}
.navigate-button::after { border: none; }
.navigate-button-hover { background: #076642; transform: scale(.985); }
.button-arrow { margin-left: 16rpx; font-size: 36rpx; font-weight: 400; }
.face-entry {
  display: flex; align-items: center;
  margin-top: 22rpx; padding: 22rpx 18rpx;
  background: #f5f7fb; border-radius: 20rpx;
}
.face-symbol {
  display: flex; align-items: center; justify-content: center;
  width: 68rpx; height: 68rpx; margin-right: 18rpx;
  color: #50658e; background: #e4eaf5;
  border-radius: 20rpx; font-size: 42rpx;
}
.face-copy { flex: 1; }
.face-title {
  display: block; color: #2e3a51;
  font-size: 27rpx; font-weight: 700;
}
.face-subtitle {
  display: block; margin-top: 5rpx;
  color: #8d98aa; font-size: 21rpx;
}
.face-arrow { color: #91a0b9; font-size: 42rpx; }
.manual-card {
  margin-top: 24rpx; padding: 30rpx 26rpx 24rpx;
  background: #fff;
  border: 1rpx solid #e6eeea; border-radius: 28rpx;
}
.manual-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 30rpx;
}
.manual-title {
  display: block; color: #1c2924;
  font-size: 34rpx; font-weight: bold;
}
.manual-subtitle {
  display: block; margin-top: 6rpx;
  color: #8a9690; font-size: 23rpx;
}
.safety-badge {
  padding: 10rpx 18rpx; color: #087a50; background: #e7f7ef;
  border-radius: 24rpx; font-size: 22rpx; font-weight: bold;
}
.manual-tip {
  display: block; margin-top: 22rpx;
  color: #97a19c; font-size: 22rpx; text-align: center;
}
.control-grid {
  display: grid;
  grid-template-columns: repeat(3, 124rpx);
  grid-template-rows: repeat(3, 124rpx);
  gap: 18rpx;
  justify-content: center;
}
.control-btn {
  box-sizing: border-box;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: #176e4b; background: #f7faf8;
  border: 2rpx solid #d3e7dc; border-radius: 50%;
  user-select: none; transition: all .08s ease;
}
.control-icon {
  height: 48rpx; font-size: 46rpx; line-height: 44rpx; font-weight: 500;
}
.control-label {
  margin-top: 4rpx; font-size: 22rpx; font-weight: bold;
}
.control-btn.forward { grid-column: 2; grid-row: 1; }
.control-btn.shift-left { grid-column: 1; grid-row: 2; }
.control-btn.stop {
  grid-column: 2; grid-row: 2;
  color: #fff; background: #e84b47;
  border: 8rpx solid #ffe6e4;
}
.stop-icon { height: 42rpx; font-size: 31rpx; line-height: 38rpx; }
.control-btn.shift-right { grid-column: 3; grid-row: 2; }
.control-btn.backward { grid-column: 2; grid-row: 3; }
.control-btn.pressed, .turn-btn.pressed {
  color: #fff; background: #087a50; border-color: #087a50;
  box-shadow: inset 0 5rpx 12rpx rgba(0, 0, 0, .12);
  transform: scale(.93);
}
.turn-title {
  display: flex; align-items: center;
  margin: 30rpx 0 14rpx; color: #7b8981; font-size: 23rpx;
}
.turn-title::before, .turn-title::after {
  content: ''; flex: 1; height: 1rpx; background: #dcebe3;
}
.turn-title::before { margin-right: 16rpx; }
.turn-title::after { margin-left: 16rpx; }
.turn-controls {
  display: flex; gap: 18rpx;
}
.turn-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 14rpx; height: 86rpx;
  color: #4e5f80; background: #f6f8fc;
  border: 2rpx solid #dfe5f0; border-radius: 43rpx;
  font-size: 25rpx; font-weight: bold;
  user-select: none; transition: all .08s ease;
}
.turn-icon { font-size: 40rpx; font-weight: normal; }
.safe-note {
  display: flex; align-items: center; justify-content: center;
  margin-top: 24rpx; color: #8b9792; font-size: 21rpx;
}
.safe-dot {
  width: 9rpx; height: 9rpx; margin-right: 10rpx;
  background: #f0a43c; border-radius: 50%;
}
