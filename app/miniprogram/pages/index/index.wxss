.header {
  background: linear-gradient(135deg, #07c160, #10ad7a);
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  margin-bottom: 32rpx;
  color: #fff;
}
.header .title { display: block; margin: 0 0 20rpx; }
.connection {
  display: flex; align-items: center; justify-content: center;
  width: 300rpx; margin: 0 auto; padding: 10rpx 22rpx;
  border-radius: 30rpx; font-size: 24rpx;
}
.connection.online { background: rgba(255, 255, 255, .22); }
.connection.offline { background: rgba(180, 30, 30, .35); }
.connection-dot {
  width: 14rpx; height: 14rpx; margin-right: 12rpx;
  border-radius: 50%; background: #fff;
}
.connection.offline .connection-dot { background: #ffd3d3; }
.section-title { font-size: 30rpx; margin: 26rpx 0 14rpx; color: #666; }
.room-list { display: flex; flex-wrap: wrap; gap: 20rpx; }
.room-item {
  width: 140rpx; height: 100rpx;
  display: flex; align-items: center; justify-content: center;
  box-sizing: border-box; background: #fff;
  border: 2rpx solid #ddd; border-radius: 12rpx; font-size: 32rpx;
}
.room-item.active {
  background: #07c160; color: #fff; border-color: #07c160;
}
.room-input {
  box-sizing: border-box; width: 100%; height: 88rpx;
  padding: 0 24rpx; background: #fff;
  border: 2rpx solid #ddd; border-radius: 12rpx;
}
.manual-card {
  margin-top: 32rpx; padding: 30rpx 26rpx 24rpx;
  background: linear-gradient(160deg, #ffffff 0%, #f1faf5 100%);
  border: 2rpx solid #dff2e7; border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(7, 193, 96, .1);
}
.manual-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 30rpx;
}
.manual-title {
  display: block; color: #1f2d26;
  font-size: 34rpx; font-weight: bold;
}
.manual-subtitle {
  display: block; margin-top: 6rpx;
  color: #8a9690; font-size: 23rpx;
}
.safety-badge {
  padding: 10rpx 18rpx; color: #078a49; background: #ddf7e8;
  border-radius: 24rpx; font-size: 22rpx; font-weight: bold;
}
.manual-tip {
  display: block; margin-top: 22rpx;
  color: #97a19c; font-size: 22rpx; text-align: center;
}
.control-grid {
  display: grid;
  grid-template-columns: repeat(3, 124rpx);
  grid-template-rows: repeat(3, 124rpx);
  gap: 18rpx;
  justify-content: center;
}
.control-btn {
  box-sizing: border-box;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: #18774a; background: #fff;
  border: 2rpx solid #ccebd9; border-radius: 50%;
  box-shadow: 0 7rpx 16rpx rgba(23, 119, 74, .1);
  user-select: none; transition: all .08s ease;
}
.control-icon {
  height: 48rpx; font-size: 46rpx; line-height: 44rpx; font-weight: 500;
}
.control-label {
  margin-top: 4rpx; font-size: 22rpx; font-weight: bold;
}
.control-btn.forward { grid-column: 2; grid-row: 1; }
.control-btn.shift-left { grid-column: 1; grid-row: 2; }
.control-btn.stop {
  grid-column: 2; grid-row: 2;
  color: #fff; background: linear-gradient(145deg, #ff6b67, #df3532);
  border: 8rpx solid #ffe0df;
  box-shadow: 0 8rpx 18rpx rgba(230, 67, 64, .25);
}
.stop-icon { height: 42rpx; font-size: 31rpx; line-height: 38rpx; }
.control-btn.shift-right { grid-column: 3; grid-row: 2; }
.control-btn.backward { grid-column: 2; grid-row: 3; }
.control-btn.pressed, .turn-btn.pressed {
  color: #fff; background: #07c160; border-color: #07c160;
  box-shadow: inset 0 5rpx 12rpx rgba(0, 0, 0, .12);
  transform: scale(.93);
}
.turn-title {
  display: flex; align-items: center;
  margin: 30rpx 0 14rpx; color: #7b8981; font-size: 23rpx;
}
.turn-title::before, .turn-title::after {
  content: ''; flex: 1; height: 1rpx; background: #dcebe3;
}
.turn-title::before { margin-right: 16rpx; }
.turn-title::after { margin-left: 16rpx; }
.turn-controls {
  display: flex; gap: 18rpx;
}
.turn-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 14rpx; height: 86rpx;
  color: #6e5b10; background: #fffdf1;
  border: 2rpx solid #f2e4a6; border-radius: 43rpx;
  font-size: 25rpx; font-weight: bold;
  box-shadow: 0 6rpx 14rpx rgba(115, 91, 0, .08);
  user-select: none; transition: all .08s ease;
}
.turn-icon { font-size: 40rpx; font-weight: normal; }
.divider { text-align: center; color: #ccc; margin: 30rpx 0; }
.btn-face { background: #8b9ab7; color: #fff; border-radius: 12rpx; }
